{
	"schemaVersion": 1,
	"id": "betel-nut-mod",
	"version": "${version}",
	"name": "Betel Nut Mod",
	"description": "A Fabric survival expansion mod featuring betel nut trees, flavored betel nuts, villager trades, Farmer's Delight integration, and an addiction HUD with withdrawal tracking.",
	"authors": [
		"寿云"
	],
	"contact": {
		"homepage": "https://space.bilibili.com/1832031043?spm_id_from=333.1007.0.0",
		"sources": "https://github.com/ikunkk02-afk/Betel-Nut-Mod"
	},
	"custom": {
		"cardinal-components": [
			"betel-nut-mod:addiction"
		]
	},
	"license": "MIT License",
	"icon": "assets/betel-nut-mod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"betel.nut.BetelNutMod"
		],
		"cardinal-components-entity": [
			"betel.nut.component.BetelNutEntityComponents"
		],
		"client": [
			"betel.nut.client.BetelNutModClient"
		],
		"fabric-datagen": [
			"betel.nut.client.BetelNutModDataGenerator"
		]
	},
	"mixins": [
		"betel-nut-mod.mixins.json",
		{
			"config": "betel-nut-mod.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.0",
		"minecraft": "1.21.1",
		"java": ">=21",
		"fabric-api": ">=0.116.11+1.21.1",
		"cardinal-components-base": ">=6.1.3 <7.0.0",
		"cardinal-components-entity": ">=6.1.3 <7.0.0"
	},
	"suggests": {
		"farmersdelight": "*"
	}
}
